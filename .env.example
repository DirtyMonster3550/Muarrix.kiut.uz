# Скопируйте в .env на сервере и задайте свои значения.
# Файл .env не публикуется в git.

PORT=3000

# Первый администратор создаётся при первом запуске, если в БД ещё нет admin.
ADMIN_EMAIL=admin@kiut.uz
ADMIN_PASSWORD=задайте_надёжный_пароль

# Обязательно смените на длинную случайную строку на production!
JWT_SECRET=длинная_случайная_строка_минимум_32_символа

# Почта (необязательно на этапе тестов)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Разрешённый origin для CORS (если фронт на другом домене)
# ALLOWED_ORIGIN=https://journal.kiut.uz
