# Copy to .env on the server and set your values.
# .env is never committed to git.

PORT=3000
NODE_ENV=production
TRUST_PROXY=1

# First admin is created on first run if no admin exists in DB.
ADMIN_EMAIL=admin@kiut.uz
ADMIN_PASSWORD=change_to_strong_password

# REQUIRED: random string at least 32 chars
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# SMTP (optional during testing)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# PDF archive directory (absolute path on server, defaults to public/archives-muarrix)
# FILE_ARCHIVE_ROOT=/var/www/muarrix.kiut.uz/archives

# Allowed CORS origin if frontend is on a separate domain
# ALLOWED_ORIGIN=https://muarrix.kiut.uz
